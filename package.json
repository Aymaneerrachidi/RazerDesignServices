{
  "name": "razer-design-services",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "node_modules/.bin/ts-node --project tsconfig.server.json prisma/seed.ts"
  },
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json server.ts",
    "build": "next build",
    "start": "NODE_ENV=production ts-node --project tsconfig.server.json server.ts",
    "lint": "next lint",
    "db:push": "node_modules/.bin/prisma db push",
    "db:migrate": "node_modules/.bin/prisma migrate dev",
    "db:studio": "node_modules/.bin/prisma studio",
    "db:seed": "ts-node --project tsconfig.server.json prisma/seed.ts",
    "db:reset": "node_modules/.bin/prisma migrate reset --force && npm run db:seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.3.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dayjs": "^1.11.12",
    "jose": "^5.6.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.416.0",
    "nanoid": "^5.0.7",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.7",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
