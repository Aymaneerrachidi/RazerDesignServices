# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/rds_db"

# ── NextAuth ───────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-to-a-random-secret-32-chars-min"
NEXTAUTH_URL="http://localhost:3000"

# ── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── SMTP (email for invites & password resets) ─────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="resend"
SMTP_PASS="re_your_resend_api_key"
SMTP_FROM="Razer Design Services <onboarding@resend.dev>"

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
